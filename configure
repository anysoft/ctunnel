#!/usr/bin/env python3
"""Convenience frontend that maps traditional flags into ctunnel Kconfig."""

from __future__ import annotations

import argparse
import os
import pathlib
import shlex
import sys

ROOT = pathlib.Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT / "scripts/kconfig"))
from ctkconfig import ConfigError, atomic_write, generate, load, new_kconfig, save_config, validate


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="configure ctunnel through .config")
    profile = parser.add_mutually_exclusive_group()
    profile.add_argument("--enable-mini", action="store_true")
    profile.add_argument("--enable-default", action="store_true")
    profile.add_argument("--enable-full", action="store_true")
    for feature in ("client", "server", "ipv4", "ipv6", "data-encryption", "work-pool", "keygen"):
        destination = feature.replace("-", "_")
        group = parser.add_mutually_exclusive_group()
        group.add_argument("--enable-" + feature, dest=destination, action="store_true")
        group.add_argument("--disable-" + feature, dest=destination, action="store_false")
        parser.set_defaults(**{destination: None})
    parser.add_argument("--with-log-level", choices=("error", "warn", "info", "debug", "trace"))
    parser.add_argument("--with-max-clients", type=int)
    parser.add_argument("--with-max-services", type=int)
    parser.add_argument("--with-max-streams", type=int)
    parser.add_argument("--with-max-pending-streams", type=int)
    parser.add_argument("--with-max-frame-size", type=int)
    parser.add_argument("--with-max-client-id-length", type=int)
    parser.add_argument("--with-max-service-id-length", type=int)
    parser.add_argument("--with-max-address-length", type=int)
    parser.add_argument("--with-max-path-length", type=int)
    parser.add_argument("--with-max-port-ranges", type=int)
    parser.add_argument("--with-stream-buffer-size", type=int)
    parser.add_argument("--with-control-buffer-size", type=int)
    parser.add_argument("--with-default-max-streams", type=int)
    parser.add_argument("--with-default-max-pending-streams", type=int)
    parser.add_argument("--with-default-pool-count", type=int)
    parser.add_argument("--with-default-pool-min", type=int)
    parser.add_argument("--with-default-pool-max", type=int)
    parser.add_argument("--enable-lto", action="store_true")
    link_mode = parser.add_mutually_exclusive_group()
    link_mode.add_argument("--enable-static", action="store_true")
    link_mode.add_argument("--enable-mostly-static", action="store_true")
    link_mode.add_argument("--enable-dynamic", action="store_true")
    parser.add_argument("--disable-tests", action="store_true")
    parser.add_argument("--with-bundled-monocypher", action="store_true")
    parser.add_argument("--with-monocypher-root", type=pathlib.Path)
    parser.add_argument("--host")
    parser.add_argument("--with-toolchain-root", type=pathlib.Path)
    parser.add_argument("--with-toolchain-file", type=pathlib.Path)
    parser.add_argument("--with-sysroot", type=pathlib.Path)
    parser.add_argument("--prefix", type=pathlib.Path, default=pathlib.Path("/usr/local"))
    parser.add_argument("--build-dir", type=pathlib.Path, default=pathlib.Path("build"))
    parser.add_argument("--config", type=pathlib.Path, default=pathlib.Path(".config"))
    return parser.parse_args()


def target_for(args: argparse.Namespace) -> str:
    if args.host:
        host = args.host.lower()
        if "mingw" in host or "windows" in host:
            return "windows"
        if "darwin" in host or "apple" in host:
            return "darwin"
        return "linux"
    return "windows" if os.name == "nt" else ("darwin" if sys.platform == "darwin" else "linux")


def set_symbol(kconf, name: str, value: str) -> None:
    symbol = kconf.syms[name]
    if not symbol.set_value(value):
        raise ConfigError(f"invalid value {value!r} for CONFIG_{name}")


def main() -> int:
    args = parse_args()
    os.chdir(ROOT)
    target = target_for(args)
    os.environ["CTUNNEL_KCONFIG_TARGET"] = target
    kconf = new_kconfig()
    if args.enable_mini:
        source = ROOT / "configs/mini_defconfig"
    elif args.enable_full:
        source = ROOT / "configs/full_defconfig"
    elif args.enable_default:
        source = ROOT / "configs/default_defconfig"
    elif args.config.exists():
        source = args.config
    else:
        source = ROOT / "configs/default_defconfig"
    load(kconf, source)

    client = kconf.syms["CTUNNEL_CLIENT"].str_value == "y" if args.client is None else args.client
    server = kconf.syms["CTUNNEL_SERVER"].str_value == "y" if args.server is None else args.server
    if not client and not server:
        raise ConfigError("--disable-client and --disable-server cannot be used together")
    role = "CTUNNEL_ROLE_BOTH" if client and server else (
        "CTUNNEL_ROLE_CLIENT_ONLY" if client else "CTUNNEL_ROLE_SERVER_ONLY")
    set_symbol(kconf, role, "y")

    feature_map = {
        "ipv4": "FEATURE_IPV4",
        "ipv6": "FEATURE_IPV6",
        "data_encryption": "FEATURE_DATA_ENCRYPTION",
        "work_pool": "FEATURE_WORK_POOL",
        "keygen": "FEATURE_KEYGEN",
    }
    for attribute, symbol in feature_map.items():
        value = getattr(args, attribute)
        if value is not None:
            set_symbol(kconf, symbol, "y" if value else "n")
    if args.work_pool is False:
        for symbol in ("DEFAULT_POOL_COUNT", "DEFAULT_POOL_MIN", "DEFAULT_POOL_MAX"):
            set_symbol(kconf, symbol, "0")
    if args.with_log_level:
        set_symbol(kconf, "LOG_MAX_LEVEL_" + args.with_log_level.upper(), "y")
    for value, symbol in (
        (args.with_max_clients, "MAX_CLIENTS"),
        (args.with_max_services, "MAX_SERVICES"),
        (args.with_max_streams, "MAX_STREAMS"),
        (args.with_max_pending_streams, "MAX_PENDING_STREAMS"),
        (args.with_max_frame_size, "MAX_FRAME_SIZE"),
        (args.with_max_client_id_length, "MAX_CLIENT_ID_LENGTH"),
        (args.with_max_service_id_length, "MAX_SERVICE_ID_LENGTH"),
        (args.with_max_address_length, "MAX_ADDRESS_LENGTH"),
        (args.with_max_path_length, "MAX_PATH_LENGTH"),
        (args.with_max_port_ranges, "MAX_PORT_RANGES"),
        (args.with_stream_buffer_size, "STREAM_BUFFER_SIZE"),
        (args.with_control_buffer_size, "CONTROL_BUFFER_SIZE"),
        (args.with_default_max_streams, "DEFAULT_MAX_STREAMS"),
        (args.with_default_max_pending_streams, "DEFAULT_MAX_PENDING_STREAMS"),
        (args.with_default_pool_count, "DEFAULT_POOL_COUNT"),
        (args.with_default_pool_min, "DEFAULT_POOL_MIN"),
        (args.with_default_pool_max, "DEFAULT_POOL_MAX"),
    ):
        if value is not None:
            set_symbol(kconf, symbol, str(value))
    if args.with_max_streams is not None:
        if int(kconf.syms["DEFAULT_MAX_STREAMS"].str_value) > args.with_max_streams:
            set_symbol(kconf, "DEFAULT_MAX_STREAMS", str(args.with_max_streams))
    if args.with_max_pending_streams is not None:
        if int(kconf.syms["DEFAULT_MAX_PENDING_STREAMS"].str_value) > args.with_max_pending_streams:
            set_symbol(kconf, "DEFAULT_MAX_PENDING_STREAMS", str(args.with_max_pending_streams))
    if args.with_default_pool_count is not None:
        for symbol in ("DEFAULT_POOL_MIN", "DEFAULT_POOL_MAX"):
            if int(kconf.syms[symbol].str_value) > args.with_default_pool_count:
                set_symbol(kconf, symbol, str(args.with_default_pool_count))
    if args.enable_lto:
        set_symbol(kconf, "ENABLE_LTO", "y")
    if args.enable_static:
        set_symbol(kconf, "CTUNNEL_LINK_STATIC", "y")
    elif args.enable_mostly_static:
        set_symbol(kconf, "CTUNNEL_LINK_MOSTLY_STATIC", "y")
    elif args.enable_dynamic:
        set_symbol(kconf, "CTUNNEL_LINK_DYNAMIC", "y")

    validate(kconf, target)
    save_config(kconf, args.config)
    generate(kconf, args.config.resolve(), args.build_dir.resolve())

    cmake_args = []
    if args.disable_tests:
        cmake_args.append("-DCTUNNEL_BUILD_TESTS=OFF")
    if args.with_monocypher_root:
        cmake_args.extend(("-DCTUNNEL_USE_BUNDLED_MONOCYPHER=OFF",
                           "-DCTUNNEL_MONOCYPHER_ROOT=" + str(args.with_monocypher_root.resolve())))
    elif args.with_bundled_monocypher:
        cmake_args.append("-DCTUNNEL_USE_BUNDLED_MONOCYPHER=ON")
    if args.with_toolchain_file:
        cmake_args.append("-DCMAKE_TOOLCHAIN_FILE=" + str(args.with_toolchain_file.resolve()))
    if args.with_sysroot:
        cmake_args.append("-DCMAKE_SYSROOT=" + str(args.with_sysroot.resolve()))
    if args.host and not args.with_toolchain_file:
        cmake_args.extend(("-DCMAKE_C_COMPILER=" + args.host + "-gcc",
                           "-DCMAKE_AR=" + args.host + "-ar",
                           "-DCMAKE_RANLIB=" + args.host + "-ranlib"))
    lines = [
        "# Generated by ./configure; contains build paths only, not feature configuration.",
        "BUILD_DIR := " + str(args.build_dir),
        "CONFIG := " + str(args.config),
        "PREFIX := " + str(args.prefix),
        "CMAKE_EXTRA_ARGS := " + " ".join(shlex.quote(item) for item in cmake_args),
    ]
    if args.with_toolchain_root:
        lines.append("export CTUNNEL_TOOLCHAIN_ROOT := " + str(args.with_toolchain_root.resolve()))
    atomic_write(ROOT / ".ctunnel-configure.mk", "\n".join(lines) + "\n")
    print(f"Configuration written to {args.config}")
    print("Run 'make' to build")
    print("Run 'make menuconfig' to review")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except ConfigError as error:
        print(f"configure: error: {error}", file=sys.stderr)
        raise SystemExit(2)
