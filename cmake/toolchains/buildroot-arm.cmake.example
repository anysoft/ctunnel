set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR arm)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)
if(NOT DEFINED ENV{CTUNNEL_TOOLCHAIN_ROOT})
  message(FATAL_ERROR "set CTUNNEL_TOOLCHAIN_ROOT to the Buildroot SDK root")
endif()
set(_root "$ENV{CTUNNEL_TOOLCHAIN_ROOT}")
file(GLOB _gcc "${_root}/bin/arm-buildroot-linux-gnueabi-gcc")
list(LENGTH _gcc _count)
if(NOT _count EQUAL 1)
  message(FATAL_ERROR "expected exactly one arm-buildroot-linux-gnueabi-gcc under ${_root}/bin")
endif()
set(CMAKE_C_COMPILER "${_root}/bin/arm-buildroot-linux-gnueabi-gcc")
set(CMAKE_AR "${_root}/bin/arm-buildroot-linux-gnueabi-ar")
set(CMAKE_RANLIB "${_root}/bin/arm-buildroot-linux-gnueabi-ranlib")
set(CMAKE_STRIP "${_root}/bin/arm-buildroot-linux-gnueabi-strip")
set(CMAKE_READELF "${_root}/bin/arm-buildroot-linux-gnueabi-readelf")
set(CMAKE_OBJDUMP "${_root}/bin/arm-buildroot-linux-gnueabi-objdump")
set(CMAKE_SIZE "${_root}/bin/arm-buildroot-linux-gnueabi-size")
set(CMAKE_SYSROOT "${_root}/arm-buildroot-linux-gnueabi/sysroot")
set(CMAKE_FIND_ROOT_PATH "${CMAKE_SYSROOT}")
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
